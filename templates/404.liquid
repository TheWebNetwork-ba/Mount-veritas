<section class="mv-404">
  <div class="mv-404-glow" aria-hidden="true"></div>
  <div class="mv-404-grain" aria-hidden="true"></div>
  <div class="mv-404-inner">
    <img class="mv-404-mark" src="{{ 'mv-mountain-gold.png' | asset_url }}" alt="" aria-hidden="true">
    <p class="mv-404-eyebrow"><span class="mv-404-code">404</span> &middot; Off the trail</p>
    <h1 class="mv-404-title">You wandered off the path.</h1>
    <p class="mv-404-sub">The route you were looking for is not on the map. Every climber loses the trail once. Here is the way back.</p>
    <div class="mv-404-actions">
      <a class="mv-404-btn" href="{{ routes.root_url }}">Return to base</a>
      <a class="mv-404-link" href="{{ routes.all_products_collection_url }}">Shop the drop &rarr;</a>
    </div>
  </div>
</section>

<style>
