<section class="cart-page" style="min-height:70vh;max-width:760px;margin:0 auto;padding:140px 24px 80px;color:#ECE9E2;font-family:'Fira Sans Condensed',sans-serif;">
  <h1 style="font-family:'Abril Fatface',serif;font-size:34px;margin:0 0 28px;">Your Cart</h1>
  {% if cart.item_count == 0 %}
    <p style="color:#9b988f;">Your cart is empty.</p>
    <a href="{{ routes.root_url }}" style="display:inline-block;margin-top:18px;color:#0d0d0b;background:#ECE9E2;padding:13px 26px;border-radius:6px;text-decoration:none;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;font-size:13px;">Continue</a>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post">
      {% for item in cart.items %}
        <div style="display:grid;grid-template-columns:72px 1fr auto;gap:16px;padding:18px 0;border-bottom:1px solid rgba(236,233,226,0.1);align-items:center;">
          <div style="width:72px;height:90px;background:#1c1c19;border-radius:6px;overflow:hidden;">
            {% if item.image %}<img src="{{ item.image | image_url: width: 200 }}" alt="" style="width:100%;height:100%;object-fit:cover;">{% endif %}
          </div>
          <div>
            <a href="{{ item.url }}" style="color:#ECE9E2;text-decoration:none;font-size:16px;">{{ item.product.title }}</a>
            {% unless item.variant.title contains 'Default' %}<div style="color:#9b988f;font-size:13px;">{{ item.variant.title }}</div>{% endunless %}
            <div style="color:#9b988f;font-size:13px;margin-top:4px;">Qty {{ item.quantity }}</div>
          </div>
          <span style="white-space:nowrap;">{{ item.final_line_price | money }}</span>
        </div>
      {% endfor %}
      <div style="display:flex;justify-content:space-between;font-weight:700;font-size:18px;margin:24px 0;">
        <span>Subtotal</span><span>{{ cart.total_price | money }}</span>
      </div>
      <button type="submit" name="checkout" style="width:100%;background:#ECE9E2;color:#0d0d0b;border:0;padding:16px;border-radius:6px;text-transform:uppercase;letter-spacing:0.14em;font-weight:700;font-size:14px;cursor:pointer;">Checkout</button>
    </form>
  {% endif %}
</section>
