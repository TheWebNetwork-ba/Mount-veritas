<style>
  .hero{ align-items:center; justify-content:center; }
  .hero-inner{
    display:flex; flex-direction:column; align-items:center;
    gap:22px; text-align:center;
    max-width:900px; margin:0 auto; padding:0 24px;
  }
  .hero-eyebrow{
    margin:0;
    font-family:'Fira Sans Condensed',sans-serif;
    font-size:11px; letter-spacing:.42em; text-transform:uppercase;
    color:#c8b273;
  }
  .hero h1{
    margin:0;
    font-family:'Abril Fatface',Georgia,serif; font-weight:400;
    font-size:clamp(34px,7vw,86px); line-height:1.02; letter-spacing:.005em;
    color:#ECE9E2;
  }
  .hero-cta{
    display:inline-block; margin-top:4px;
    font-family:'Fira Sans Condensed',sans-serif;
    font-size:11px; letter-spacing:.34em; text-transform:uppercase;
    color:#ECE9E2; text-decoration:none;
    padding-bottom:6px; border-bottom:1px solid rgba(236,233,226,.38);
    transition:border-color .3s ease,color .3s ease;
  }
  .hero-cta:hover{ border-color:#c8b273; color:#c8b273; }

  .mtn-card--soon{
    opacity:1;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:14px;
    background:#0f0f0d;
  }
  .mtn-soon-logo{ position:relative; z-index:2; }
  .mtn-soon-logo svg{ width:44px; height:44px; display:block; }
  .mtn-card--soon .mtn-card-shade{ opacity:0.4; }
  .mtn-card--soon .mtn-card-name{
    position:relative;
    left:auto; right:auto; bottom:auto;
    z-index:2;
    text-align:center;
    font-size:11px;
    letter-spacing:0.22em;
    color:#9b988f;
  }
  @media (max-width:640px){
    .hero h1{ font-size:clamp(30px,10vw,48px); }
    .hero-inner{ gap:18px; padding:0 20px; }
  }

  .firstpieces .fp-cta{ background:none; border:none; border-radius:0; padding:0 0 6px; color:#ECE9E2; border-bottom:1px solid rgba(236,233,226,.38); font-family:'Fira Sans Condensed',sans-serif; font-size:11px; letter-spacing:.34em; text-transform:uppercase; transition:border-color .3s ease,color .3s ease; }
  .firstpieces .fp-link:hover .fp-cta{ background:none; border-color:#c8b273; color:#c8b273; }
</style>

<div class="slides">

  <header class="slide hero">
    {% if section.settings.hero_image != blank %}
      <div class="slide-bg"><img src="{{ section.settings.hero_image | image_url: width: 2400 }}" alt="" loading="lazy"><span class="slide-shade"></span></div>
    {% endif %}
    <div class="hero-inner">
      <span class="hero-eyebrow">See it. Believe it. Obtain it.</span>
      <h1>Wear the Greater Man.</h1>
      <a class="hero-cta" href="{{ section.settings.fp_link | default: routes.all_products_collection_url }}">Shop the drop</a>
    </div>
  </header>

  <section class="slide firstpieces" id="shop" aria-label="The First Ascent">
    <a class="fp-link" href="{{ section.settings.fp_link | default: routes.all_products_collection_url }}">
      {% if section.settings.fp_image != blank %}
        <div class="fp-bg">
          <img src="{{ section.settings.fp_image | image_url: width: 2400 }}" alt="" loading="lazy">
          <span class="fp-shade"></span>
        </div>
      {% endif %}
      <div class="fp-inner">
        {% if section.settings.fp_eyebrow != blank %}<span class="fp-eyebrow">{{ section.settings.fp_eyebrow | escape }}</span>{% endif %}
        <h2 class="fp-title">{{ section.settings.fp_title | default: 'Where the climb begins.' | escape }}</h2>
        <span class="fp-cta">{{ section.settings.fp_cta | default: 'See the piece' | escape }} &rarr;</span>
      </div>
    </a>
  </section>

  <section class="slide mountain" aria-label="The Mountain Collection">
    {% if section.settings.mtn_image != blank %}
      <div class="slide-bg"><img src="{{ section.settings.mtn_image | image_url: width: 2400 }}" alt="" loading="lazy"><span class="slide-shade"></span></div>
    {% endif %}
    <div class="mtn-inner">
      <div class="mtn-head">
        {% if section.settings.mtn_eyebrow != blank %}<span class="mtn-eyebrow">{{ section.settings.mtn_eyebrow | escape }}</span>{% endif %}
        <h2 class="mtn-title">{{ section.settings.mtn_title | default: 'Built for the climb.' | escape }}</h2>
        {% if section.settings.mtn_text != blank %}<p class="mtn-text">{{ section.settings.mtn_text | escape }}</p>{% endif %}
      </div>
      <div class="mtn-grid">
        {% for n in (1..4) %}
          {% assign mkey = 'mtn_collection_' | append: n %}
          {% assign col = section.settings[mkey] %}
          {% if col != blank %}
            {% assign cimg = col.image %}
            {% unless cimg %}{% assign cimg = col.products.first.featured_image %}{% endunless %}
            <a class="mtn-card" href="{{ col.url }}">
              {% if cimg %}<img src="{{ cimg | image_url: width: 900 }}" alt="{{ col.title | escape }}" loading="lazy">{% endif %}
              <span class="mtn-card-shade"></span>
              <span class="mtn-card-name">{{ col.title }}</span>
            </a>
          {% else %}
            <div class="mtn-card mtn-card--soon">
              <span class="mtn-card-shade"></span>
              <div class="mtn-soon-logo">
                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M32 10 L56 52 H8 Z" stroke="#ECE9E2" stroke-width="1.4" stroke-linejoin="round"/>
                  <path d="M22 52 L32 30 L42 52" stroke="#ECE9E2" stroke-width="1" stroke-linejoin="round" opacity="0.45"/>
                </svg>
              </div>
              <span class="mtn-card-name">Coming soon</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "MV Home",
  "settings": [
    { "type": "header", "content": "Slide 1 — Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Background image (optional)" },

    { "type": "header", "content": "Slide 2 — First Ascent" },
    { "type": "text", "id": "fp_eyebrow", "label": "Eyebrow (gold text)", "default": "Collection 01" },
    { "type": "text", "id": "fp_title", "label": "Headline", "default": "Where the climb begins." },
    { "type": "text", "id": "fp_cta", "label": "Button text", "default": "See the piece" },
    { "type": "image_picker", "id": "fp_image", "label": "Background image (optional)" },
    { "type": "url", "id": "fp_link", "label": "Link (blank = all products)" },

    { "type": "header", "content": "Slide 3 — Mountain Collection" },
    { "type": "text", "id": "mtn_eyebrow", "label": "Eyebrow (gold text)", "default": "The Mountain Collection" },
    { "type": "text", "id": "mtn_title", "label": "Headline", "default": "Built for the climb." },
    { "type": "text", "id": "mtn_text", "label": "Sub text", "default": "Four collections. One ascent." },
    { "type": "image_picker", "id": "mtn_image", "label": "Background image (optional)" },
    { "type": "collection", "id": "mtn_collection_1", "label": "Collection 1" },
    { "type": "collection", "id": "mtn_collection_2", "label": "Collection 2" },
    { "type": "collection", "id": "mtn_collection_3", "label": "Collection 3" },
    { "type": "collection", "id": "mtn_collection_4", "label": "Collection 4" }
  ],
  "blocks": [],
  "presets": [ { "name": "MV Home" } ]
}
{% endschema %}
