<section class="pdp" aria-label="Product">
  <div class="pdp-grid">

    <div class="pdp-media">
      <div class="pdp-main">
        {% if product.featured_image %}
          <img id="pdpImg" src="{{ product.featured_image | image_url: width: 1400 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" width="1400" height="1750">
        {% else %}
          <svg class="pdp-ph" viewBox="0 0 100 100" aria-hidden="true"><path d="M30 18 L42 12 Q50 18 58 12 L70 18 L82 32 L70 42 L70 88 L30 88 L30 42 L18 32 Z" fill="none" stroke="#56544d" stroke-width="1.4"/></svg>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="pdp-thumbs">
          {% for image in product.images limit: 6 %}
            <button type="button" class="pdp-thumb{% if forloop.first %} is-active{% endif %}" data-img="{{ image | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 160 }}" alt="" loading="lazy">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="pdp-info">
      <a class="pdp-back" href="/collections/all">&larr; All pieces</a>
      <h1 class="pdp-title">{{ product.title }}</h1>

      <div class="pdp-price">
        <span id="pdpPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
        {% if product.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="pdp-compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% form 'product', product %}
        {% assign cv = product.selected_or_first_available_variant %}

        <input type="hidden" name="id" id="pdpVariantId" value="{{ cv.id }}">

        {% unless product.has_only_default_variant %}
          <div class="pdp-opts">
            {% for option in product.options_with_values %}
              {% assign oname = option.name | downcase %}
              <div class="pdp-optbox" data-opt-index="{{ forloop.index }}">
                <span class="pdp-optname">{{ option.name }}</span>
                <div class="pdp-chips">
                  {% for value in option.values %}
                    <button type="button" class="pdp-chip{% if option.selected_value == value %} is-sel{% endif %}" data-val="{{ value | escape }}">{{ value }}</button>
                  {% endfor %}
                </div>
                {% if oname contains 'size' %}
                  <button type="button" class="pdp-sizechart js-sizechart-open">Size chart</button>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <script type="application/json" id="pdpVariantData">{{ product.variants | json }}</script>

        <div class="pdp-qty">
          <button type="button" class="pdp-qd" data-act="dec" aria-label="Decrease quantity">&#8722;</button>
          <input type="number" id="pdpQty" name="quantity" value="1" min="1" inputmode="numeric">
          <button type="button" class="pdp-qd" data-act="inc" aria-label="Increase quantity">+</button>
        </div>

        <button type="submit" name="add" id="pdpAdd" class="pdp-add"{% unless cv.available %} disabled{% endunless %}>
          {% if cv.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>

        {{ form | payment_button }}
      {% endform %}

      {% if section.blocks.size > 0 %}
        <div class="pdp-acc">
          {% for block in section.blocks %}
            <div class="pdp-acc-item" {{ block.shopify_attributes }}>
              <button class="pdp-acc-q" type="button" aria-expanded="false">
                <span>{{ block.settings.heading | escape }}</span>
                <span class="pdp-acc-ic" aria-hidden="true">+</span>
              </button>
              <div class="pdp-acc-a">
                <div class="pdp-acc-a-inner">
                  {%- if block.settings.use_description -%}
                    {{ product.description | default: '<p>Details coming soon.</p>' }}
                  {%- else -%}
                    {{ block.settings.content }}
                  {%- endif -%}
                  {%- assign bh = block.settings.heading | downcase -%}
                  {%- if bh contains 'size' -%}
                    <button type="button" class="pdp-acc-sizechart js-sizechart-open">View size chart &rarr;</button>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {%- assign pp = product.metafields.custom.pair_product.value -%}
      {%- if pp != blank and pp.title != blank -%}
        <div class="pdp-pair">
          <span class="pdp-pair-title">{{ section.settings.pair_title | default: 'Make it a Pair' }}</span>
          <div class="pdp-pair-card">
            <a class="pdp-pair-img" href="{{ pp.url }}">{% if pp.featured_image %}<img src="{{ pp.featured_image | image_url: width: 200 }}" alt="{{ pp.title | escape }}">{% endif %}</a>
            <div class="pdp-pair-info">
              <a class="pdp-pair-name" href="{{ pp.url }}">{{ pp.title }}</a>
              <span class="pdp-pair-price">{{ pp.price | money }}</span>
            </div>
            <form action="{{ routes.cart_add_url }}" method="post" class="pdp-pair-form">
              <input type="hidden" name="id" value="{{ pp.selected_or_first_available_variant.id }}">
              <button type="submit" name="add" class="pdp-pair-add"{% unless pp.available %} disabled{% endunless %}>{% if pp.available %}Add{% else %}Sold out{% endif %}</button>
            </form>
          </div>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<div class="cart-overlay" id="sizeOverlay" aria-hidden="true"></div>
<aside class="sizechart-drawer" id="sizeDrawer" aria-label="Size chart" aria-hidden="true">
  <div class="sizechart-head">
    <span class="sizechart-title">Size Chart</span>
    <button class="sizechart-close" id="sizeChartClose" type="button" aria-label="Close size chart">&times;</button>
  </div>
  <div class="sizechart-body">
    {%- assign chart_mf = product.metafields.custom.size_chart -%}
    {%- if chart_mf != blank and chart_mf.value != blank -%}
      <img src="{{ chart_mf.value | image_url: width: 1400 }}" alt="{{ product.title | escape }} size chart" loading="lazy">
    {%- else -%}
      <p class="sizechart-empty">No size chart for this product yet.<br><br>Add one under <strong>Products &rarr; this product &rarr; Metafields &rarr; Size chart</strong> &rarr; upload the image. Every product gets its own.</p>
    {%- endif -%}
  </div>
</aside>

<div class="pdp-zoom" id="pdpZoom" aria-hidden="true">
  <button class="pdp-zoom-close" id="pdpZoomClose" type="button" aria-label="Close zoom">&times;</button>
  <img id="pdpZoomImg" src="" alt="">
</div>

{% schema %}
{
  "name": "MV Product",
  "settings": [
    { "type": "header", "content": "Pair offer" },
    { "type": "text", "id": "pair_title", "label": "Pair offer label", "default": "Make it a Pair for 10% Off", "info": "Shared label only. The actual paired product is chosen per-product." },
    { "type": "paragraph", "content": "Size chart and pair product are set PER PRODUCT: Products > (open a product) > Metafields. Each product gets its own. Set the real discount in Shopify > Discounts." }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Accordion panel",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
        { "type": "checkbox", "id": "use_description", "label": "Pull text from the product description", "default": false },
        { "type": "richtext", "id": "content", "label": "Text", "default": "<p>Add details here.</p>", "info": "Ignored when 'Pull text from the product description' is on." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "MV Product",
      "blocks": [
        { "type": "panel", "settings": { "heading": "Details", "use_description": true } },
        { "type": "panel", "settings": { "heading": "Shipping" } },
        { "type": "panel", "settings": { "heading": "Size & Fit" } }
      ]
    }
  ]
}
{% endschema %}
