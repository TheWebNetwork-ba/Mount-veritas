<div class="mv-gate"{% if section.settings.background_image %} style="background-image:linear-gradient(rgba(13,13,11,.55),rgba(13,13,11,.62)),url({{ section.settings.background_image | image_url: width: 2200 }});"{% endif %}>
  <div class="mv-gate-inner">

    <div class="mv-gate-wordmark">Mount Veritas</div>

    <div class="mv-gate-mid">
      <div class="mv-gate-box">
        {% if section.settings.eyebrow != blank %}<p class="mv-gate-eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
        <h1 class="mv-gate-title">{{ section.settings.headline | default: 'The ascent begins soon.' }}</h1>
        {% if section.settings.subtext != blank %}<p class="mv-gate-sub">{{ section.settings.subtext }}</p>{% endif %}

        {% form 'customer' %}
          {% if form.posted_successfully? %}{% assign mv_joined = true %}{% endif %}
          <input type="hidden" name="contact[tags]" value="waitlist">
          <input type="hidden" name="contact[note]" value="waitlist-gate">
          <input class="mv-gate-input" type="text" name="contact[first_name]" placeholder="First name" aria-label="First name" autocomplete="given-name">
          <input class="mv-gate-input" type="email" name="contact[email]" placeholder="Email" aria-label="Email" autocomplete="email" required>
          <button class="mv-gate-btn" type="submit">{{ section.settings.button_label | default: 'Join the waitlist' }}</button>
          {% if form.errors %}<p class="mv-gate-formerr">That didn't go through &mdash; check your email and try again.</p>{% endif %}
        {% endform %}
      </div>

      {% if mv_joined %}
        <div class="mv-gate-success" role="status">
          <span class="mv-gate-success-ic" aria-hidden="true">&#10003;</span>
          <span class="mv-gate-success-tx">{{ section.settings.success_message | default: "You're on the list. Your climb starts in your inbox." }}</span>
        </div>
      {% endif %}
    </div>

    <div class="mv-gate-access">
      <p class="mv-gate-access-label">{{ section.settings.access_label | default: 'Have access?' }}</p>
      {% form 'storefront_password', id: 'mv-pw-form' %}
        <div class="mv-gate-access-row">
          <input class="mv-gate-pw" type="password" name="password" placeholder="Enter password" aria-label="Store password">
          <button class="mv-gate-pw-btn" type="submit" aria-label="Enter store">&rarr;</button>
        </div>
        <p class="mv-gate-pwerr" id="mv-pw-err"{% unless form.errors %} hidden{% endunless %}>Wrong password &mdash; try again.</p>
      {% endform %}
    </div>

  </div>
</div>

<style>
.mv-gate{ min-height:100svh; background:#0d0d0b; background-size:cover; background-position:center; display:flex; }
.mv-gate-inner{ width:100%; max-width:560px; margin:0 auto; padding:40px 22px; display:flex; flex-direction:column; justify-content:space-between; min-height:100svh; box-sizing:border-box; }
.mv-gate-wordmark{ text-align:center; font-family:'Fira Sans Condensed',sans-serif; color:#cfcabf; font-size:13px; letter-spacing:3px; }
.mv-gate-box{ background:rgba(13,13,11,.82); border:1px solid rgba(236,233,226,.12); border-radius:6px; padding:30px 26px; }
.mv-gate-eyebrow{ text-align:center; font-family:'Fira Sans Condensed',sans-serif; color:#ffb800; font-size:12px; letter-spacing:2px; margin:0 0 14px; }
.mv-gate-title{ text-align:center; font-family:'Abril Fatface',serif; font-weight:400; color:#ECE9E2; font-size:clamp(28px,7vw,40px); line-height:1.06; margin:0 0 12px; }
.mv-gate-sub{ text-align:center; font-family:'Fira Sans Condensed',sans-serif; color:#9b988f; font-size:14px; line-height:1.55; margin:0 0 22px; }
.mv-gate-input{ width:100%; box-sizing:border-box; background:#0f0f0d; border:1px solid #3a392f; border-radius:6px; padding:13px 15px; color:#ECE9E2; font-family:'Fira Sans Condensed',sans-serif; font-size:15px; margin-bottom:10px; }
.mv-gate-input::placeholder{ color:#6f6c64; }
.mv-gate-input:focus{ outline:none; border-color:#ECE9E2; }
.mv-gate-btn{ width:100%; background:#ECE9E2; color:#0d0d0b; border:none; border-radius:6px; padding:14px; font-family:'Fira Sans Condensed',sans-serif; font-weight:500; font-size:15px; letter-spacing:.3px; cursor:pointer; margin-top:4px; }
.mv-gate-btn:hover{ background:#ffffff; }
.mv-gate-formerr{ text-align:center; color:#d9a066; font-family:'Fira Sans Condensed',sans-serif; font-size:13px; margin:12px 0 0; }
.mv-gate-success{ max-width:340px; margin:16px auto 0; background:rgba(111,191,142,.12); border:1px solid rgba(111,191,142,.32); border-radius:6px; padding:13px 16px; display:flex; align-items:center; gap:10px; justify-content:center; }
.mv-gate-success-ic{ color:#8fd3a8; font-size:16px; }
.mv-gate-success-tx{ font-family:'Fira Sans Condensed',sans-serif; color:#9bd8b4; font-size:13.5px; line-height:1.4; }
.mv-gate-access-label{ text-align:center; font-family:'Fira Sans Condensed',sans-serif; color:#9b988f; font-size:12px; letter-spacing:.5px; margin:0 0 8px; }
.mv-gate-access-row{ display:flex; gap:8px; max-width:280px; margin:0 auto; }
.mv-gate-pw{ flex:1; box-sizing:border-box; background:rgba(13,13,11,.55); border:1px solid #3a392f; border-radius:6px; padding:11px 13px; color:#ECE9E2; font-family:'Fira Sans Condensed',sans-serif; font-size:14px; }
.mv-gate-pw::placeholder{ color:#6f6c64; }
.mv-gate-pw:focus{ outline:none; border-color:#ECE9E2; }
.mv-gate-pw-btn{ width:46px; background:transparent; border:1px solid #4a483d; border-radius:6px; color:#cfcabf; font-size:18px; cursor:pointer; }
.mv-gate-pw-btn:hover{ border-color:#ECE9E2; color:#ECE9E2; }
.mv-gate-pwerr{ text-align:center; color:#d98a8a; font-family:'Fira Sans Condensed',sans-serif; font-size:12px; margin:8px 0 0; }
@media (max-width:600px){ .mv-gate-box{ padding:26px 20px; } }
</style>

<script>
(function(){
  var form = document.getElementById('mv-pw-form');
  if(!form) return;
  var err = document.getElementById('mv-pw-err');
  form.addEventListener('submit', function(e){
    e.preventDefault();
    if(err) err.hidden = true;
    var btn = form.querySelector('button[type="submit"]');
    if(btn) btn.disabled = true;
    var data = new FormData(form);
    fetch('/password', { method:'POST', body:data, headers:{'Accept':'text/html'} })
      .then(function(){ return fetch('/', { cache:'no-store' }); })
      .then(function(r){ return r.text(); })
      .then(function(html){
        if(html.indexOf('mv-gate') !== -1){
          if(err) err.hidden = false;
          if(btn) btn.disabled = false;
        } else {
          window.location.assign('/');
        }
      })
      .catch(function(){ window.location.assign('/'); });
  });
})();
</script>

{% schema %}
{
  "name": "Waitlist gate",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image", "info": "Fills the whole page behind the box. Leave empty for solid dark." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Base camp" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "The ascent begins soon." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Join the list to be first through the gate when the first pieces release." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the waitlist" },
    { "type": "text", "id": "success_message", "label": "Success message (after joining)", "default": "You're on the list. Your climb starts in your inbox." },
    { "type": "text", "id": "access_label", "label": "Access prompt", "default": "Have access?" }
  ],
  "presets": [{ "name": "Waitlist gate" }]
}
{% endschema %}


