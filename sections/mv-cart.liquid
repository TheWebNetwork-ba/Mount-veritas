<section class="mv-cart">
  <div class="mv-cart-inner">
    <h1 class="mv-cart-title">Your cart</h1>

    {% if cart.item_count == 0 %}
      <div class="mv-cart-empty">
        <p class="mv-cart-empty-text">Your cart is empty.</p>
        <a class="mv-cart-empty-btn" href="{{ routes.root_url }}">Continue shopping</a>
      </div>

    {% else %}
      <form action="{{ routes.cart_url }}" method="post" id="mv-cart-form">

        {%- comment -%} ── CART ITEMS ── {%- endcomment -%}
        <div class="mv-cart-items">
          {% for item in cart.items %}
            <div class="mv-cart-item">
              <div class="mv-cart-item-img">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">
                {% endif %}
              </div>
              <div class="mv-cart-item-info">
                <a class="mv-cart-item-name" href="{{ item.url }}">{{ item.product.title }}</a>
                {% unless item.variant.title contains 'Default' %}
                  <p class="mv-cart-item-variant">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="mv-cart-item-qty">Qty {{ item.quantity }}</p>
              </div>
              <span class="mv-cart-item-price">{{ item.final_line_price | money }}</span>
            </div>
          {% endfor %}
        </div>

        {%- comment -%} ── EARLY ACCESS UPSELL ── {%- endcomment -%}
        {% if section.settings.early_access_product != blank %}
          {% assign ea_product = section.settings.early_access_product %}
          {% unless cart.items | map: 'product_id' | contains: ea_product.id %}
            <div class="mv-cart-upsell">
              <div class="mv-cart-upsell-img">
                {% if ea_product.featured_image %}
                  <img src="{{ ea_product.featured_image | image_url: width: 120 }}" alt="{{ ea_product.title }}">
                {% else %}
                  <div class="mv-cart-upsell-img-empty"></div>
                {% endif %}
              </div>
              <div class="mv-cart-upsell-info">
                <p class="mv-cart-upsell-label">{{ section.settings.early_access_label | default: 'Add on' }}</p>
                <p class="mv-cart-upsell-name">{{ ea_product.title }}</p>
                <p class="mv-cart-upsell-price">{{ ea_product.price | money }}</p>
              </div>
              <button class="mv-cart-upsell-btn" type="button"
                data-product-id="{{ ea_product.variants.first.id }}"
                onclick="mvAddToCart(this)">
                Add
              </button>
            </div>
          {% endunless %}
        {% endif %}

        {%- comment -%} ── PACKAGE PROTECTION ── {%- endcomment -%}
        {% if section.settings.protection_product != blank %}
          {% assign pp_product = section.settings.protection_product %}
          {% unless cart.items | map: 'product_id' | contains: pp_product.id %}
            <div class="mv-cart-protection">
              <div class="mv-cart-protection-left">
                <div class="mv-cart-protection-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l7 4v6c0 4.4-3 8.3-7 9.3C8 21.3 5 17.4 5 13V6l7-4z"/></svg>
                </div>
                <div>
                  <p class="mv-cart-protection-name">{{ pp_product.title }}</p>
                  <p class="mv-cart-protection-price">{{ pp_product.price | money }}</p>
                </div>
              </div>
              <button class="mv-cart-protection-btn" type="button"
                data-product-id="{{ pp_product.variants.first.id }}"
                onclick="mvAddToCart(this)">
                + Add
              </button>
            </div>
          {% endunless %}
        {% endif %}

        {%- comment -%} ── SUBTOTAL ── {%- endcomment -%}
        <div class="mv-cart-subtotal">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        {%- comment -%} ── CHECKOUT ── {%- endcomment -%}
        <button class="mv-cart-checkout" type="submit" name="checkout">
          Checkout
        </button>

        {%- comment -%} ── PAYMENT ICONS ── {%- endcomment -%}
        <div class="mv-cart-payments">
          {% assign payment_types = 'shopify_pay,visa,master,american_express,diners_club,discover,apple_pay,google_pay' | split: ',' %}
          {% for type in payment_types %}
            <img class="mv-cart-payment-icon"
              src="{{ type | payment_type_img_url: 'small' }}"
              alt="{{ type | replace: '_', ' ' | capitalize }}"
              width="38" height="24">
          {% endfor %}
        </div>

      </form>
    {% endif %}
  </div>
</section>

<style>
.mv-cart{ min-height:70vh; padding:140px 24px 80px; box-sizing:border-box; }
.mv-cart-inner{ max-width:640px; margin:0 auto; font-family:'Fira Sans Condensed',sans-serif; color:#ECE9E2; }
.mv-cart-title{ font-family:'Abril Fatface',serif; font-weight:400; font-size:34px; margin:0 0 28px; }

/* Empty */
.mv-cart-empty{ }
.mv-cart-empty-text{ color:#9b988f; margin:0 0 18px; }
.mv-cart-empty-btn{ display:inline-block; background:#ECE9E2; color:#0d0d0b; padding:13px 26px; border-radius:6px; text-decoration:none; text-transform:uppercase; letter-spacing:.12em; font-weight:700; font-size:13px; }

/* Items */
.mv-cart-items{ border-top:1px solid rgba(236,233,226,.1); }
.mv-cart-item{ display:grid; grid-template-columns:72px 1fr auto; gap:16px; padding:18px 0; border-bottom:1px solid rgba(236,233,226,.1); align-items:center; }
.mv-cart-item-img{ width:72px; height:90px; background:#1c1c19; border-radius:6px; overflow:hidden; flex:none; }
.mv-cart-item-img img{ width:100%; height:100%; object-fit:cover; }
.mv-cart-item-name{ color:#ECE9E2; text-decoration:none; font-size:16px; display:block; margin:0 0 4px; }
.mv-cart-item-variant,.mv-cart-item-qty{ color:#9b988f; font-size:13px; margin:0; }
.mv-cart-item-price{ white-space:nowrap; font-size:15px; }

/* Early access upsell */
.mv-cart-upsell{ display:flex; align-items:center; gap:14px; padding:16px; margin-top:12px; background:#111110; border:1px solid rgba(236,233,226,.1); border-radius:6px; }
.mv-cart-upsell-img{ width:56px; height:68px; background:#1c1c19; border-radius:4px; overflow:hidden; flex:none; }
.mv-cart-upsell-img img{ width:100%; height:100%; object-fit:cover; }
.mv-cart-upsell-img-empty{ width:100%; height:100%; }
.mv-cart-upsell-info{ flex:1; min-width:0; }
.mv-cart-upsell-label{ font-size:10px; letter-spacing:.18em; text-transform:uppercase; color:#ffb800; margin:0 0 3px; }
.mv-cart-upsell-name{ font-size:14px; color:#ECE9E2; margin:0 0 3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mv-cart-upsell-price{ font-size:13px; color:#9b988f; margin:0; }
.mv-cart-upsell-btn{ flex:none; background:#ECE9E2; color:#0d0d0b; border:none; border-radius:6px; padding:10px 18px; font-family:'Fira Sans Condensed',sans-serif; font-weight:700; font-size:12px; letter-spacing:.08em; text-transform:uppercase; cursor:pointer; transition:background .2s; white-space:nowrap; }
.mv-cart-upsell-btn:hover{ background:#fff; }

/* Package protection */
.mv-cart-protection{ display:flex; align-items:center; justify-content:space-between; gap:12px; padding:12px 16px; margin-top:8px; background:rgba(111,191,142,.06); border:1px solid rgba(111,191,142,.18); border-radius:6px; }
.mv-cart-protection-left{ display:flex; align-items:center; gap:10px; }
.mv-cart-protection-icon{ width:28px; height:28px; color:#8fd3a8; flex:none; }
.mv-cart-protection-icon svg{ width:100%; height:100%; }
.mv-cart-protection-name{ font-size:13px; color:#ECE9E2; margin:0 0 2px; }
.mv-cart-protection-price{ font-size:12px; color:#9b988f; margin:0; }
.mv-cart-protection-btn{ flex:none; background:transparent; color:#8fd3a8; border:1px solid rgba(143,211,168,.35); border-radius:6px; padding:7px 14px; font-family:'Fira Sans Condensed',sans-serif; font-weight:700; font-size:12px; letter-spacing:.06em; text-transform:uppercase; cursor:pointer; transition:background .2s,color .2s; white-space:nowrap; }
.mv-cart-protection-btn:hover{ background:rgba(143,211,168,.12); }

/* Subtotal */
.mv-cart-subtotal{ display:flex; justify-content:space-between; font-weight:700; font-size:18px; margin:20px 0 14px; padding-top:20px; border-top:1px solid rgba(236,233,226,.1); }

/* Checkout */
.mv-cart-checkout{ width:100%; background:#ECE9E2; color:#0d0d0b; border:0; padding:16px; border-radius:6px; text-transform:uppercase; letter-spacing:.14em; font-weight:700; font-size:14px; cursor:pointer; font-family:'Fira Sans Condensed',sans-serif; transition:background .2s; }
.mv-cart-checkout:hover{ background:#fff; }

/* Payment icons */
.mv-cart-payments{ display:flex; flex-wrap:wrap; justify-content:center; gap:6px; margin-top:14px; }
.mv-cart-payment-icon{ height:24px; width:auto; border-radius:3px; opacity:.75; }
</style>

<script>
function mvAddToCart(btn){
  var id = btn.getAttribute('data-product-id');
  btn.disabled = true;
  btn.textContent = '...';
  fetch('/cart/add.js', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ id: id, quantity: 1 })
  })
  .then(function(r){ return r.json(); })
  .then(function(){
    window.location.reload();
  })
  .catch(function(){
    btn.disabled = false;
    btn.textContent = 'Add';
  });
}
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "product",
      "id": "early_access_product",
      "label": "Early access upsell product",
      "info": "Shown above package protection. Leave empty to hide."
    },
    {
      "type": "text",
      "id": "early_access_label",
      "label": "Early access eyebrow label",
      "default": "Exclusive add-on"
    },
    {
      "type": "product",
      "id": "protection_product",
      "label": "Package protection product",
      "info": "Shown as small green row above subtotal. Leave empty to hide."
    }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
