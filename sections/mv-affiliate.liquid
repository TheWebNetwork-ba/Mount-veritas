<div class="mv-aff"{% if section.settings.background_image %} style="background-image:linear-gradient(rgba(13,13,11,.60),rgba(13,13,11,.72)),url({{ section.settings.background_image | image_url: width: 2200 }});background-size:cover;background-position:center;"{% endif %}>
  <div class="mv-aff-inner">

    <div class="mv-aff-top">
      {% if section.settings.eyebrow != blank %}<p class="mv-aff-eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}
      <h1 class="mv-aff-title">{{ section.settings.headline | default: 'Affiliate program' }}</h1>
      {% if section.settings.subtext != blank %}<p class="mv-aff-sub">{{ section.settings.subtext }}</p>{% endif %}
    </div>

    <div class="mv-aff-box">
      <a class="mv-aff-btn-primary" href="https://Mountveritas.bixgrow.com/login">Sign in</a>
      <div class="mv-aff-divider"><span>or</span></div>
      <a class="mv-aff-btn-secondary" href="https://Mountveritas.bixgrow.com/register">Join the program &rarr;</a>
    </div>

  </div>
</div>

<style>
.mv-aff{
  min-height:100svh; background:#0d0d0b;
  display:flex; align-items:center; justify-content:center;
}
.mv-aff-inner{
  width:100%; max-width:460px; margin:0 auto;
  padding:120px 24px 80px; display:flex; flex-direction:column; gap:36px;
}
.mv-aff-top{ text-align:center; }
.mv-aff-eyebrow{
  font-family:"Fira Sans Condensed",sans-serif; font-size:11px;
  letter-spacing:.45em; text-transform:uppercase; color:#ffb800; margin:0 0 12px;
}
.mv-aff-title{
  font-family:"Abril Fatface",serif; font-weight:400; color:#ECE9E2;
  font-size:clamp(32px,6vw,52px); line-height:1.04; margin:0 0 14px;
}
.mv-aff-sub{
  font-family:"Fira Sans Condensed",sans-serif; color:#9b988f;
  font-size:15px; line-height:1.6; margin:0;
}
.mv-aff-box{
  background:rgba(13,13,11,.85); border:1px solid rgba(236,233,226,.12);
  border-radius:6px; padding:32px 28px; display:flex; flex-direction:column; gap:0;
}
.mv-aff-btn-primary{
  display:block; width:100%; box-sizing:border-box; text-align:center;
  background:#ECE9E2; color:#0d0d0b; border-radius:6px;
  padding:15px; font-family:"Fira Sans Condensed",sans-serif; font-weight:700;
  font-size:14px; letter-spacing:.08em; text-transform:uppercase;
  text-decoration:none; transition:background .2s;
}
.mv-aff-btn-primary:hover{ background:#fff; }
.mv-aff-btn-secondary{
  display:block; width:100%; box-sizing:border-box; text-align:center;
  background:transparent; color:#ECE9E2; border:1px solid rgba(236,233,226,.25);
  border-radius:6px; padding:15px; font-family:"Fira Sans Condensed",sans-serif;
  font-weight:600; font-size:14px; letter-spacing:.04em;
  text-decoration:none; transition:border-color .2s, color .2s;
}
.mv-aff-btn-secondary:hover{ border-color:#ECE9E2; color:#fff; }
.mv-aff-divider{
  display:flex; align-items:center; gap:12px;
  margin:20px 0; color:#56544d;
  font-family:"Fira Sans Condensed",sans-serif; font-size:12px;
  letter-spacing:.1em; text-transform:uppercase;
}
.mv-aff-divider::before,.mv-aff-divider::after{
  content:""; flex:1; height:1px; background:rgba(236,233,226,.1);
}
@media(max-width:480px){ .mv-aff-box{ padding:26px 18px; } }
</style>

{% schema %}
{
  "name": "Affiliate program",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Background image", "info": "Full-page background. Leave empty for solid dark." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The climb" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Affiliate program" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Join the movement. Share the brand. Earn your place." }
  ],
  "presets": [{ "name": "Affiliate program" }]
}
{% endschema %}