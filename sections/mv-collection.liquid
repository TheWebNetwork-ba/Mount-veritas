{% paginate collection.products by 24 %}
<section class="catalog" aria-label="Catalog">
  <div class="catalog-head">
    <h1 class="catalog-title">{{ collection.title | default: 'The Catalog' }}</h1>
    <span class="catalog-count">{{ collection.products_count }} {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}</span>
  </div>

  {% if collection.products_count > 0 %}
    <div class="catalog-grid">
      {% for product in collection.products %}
        <a class="cat-card" href="{{ product.url }}">
          <div class="cat-card-img">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="lazy">
            {% else %}
              <svg viewBox="0 0 100 100" aria-hidden="true"><path d="M30 18 L42 12 Q50 18 58 12 L70 18 L82 32 L70 42 L70 88 L30 88 L30 42 L18 32 Z" fill="none" stroke="#56544d" stroke-width="1.4"/></svg>
            {% endif %}
            {% unless product.available %}<span class="cat-soldout">Sold out</span>{% endunless %}
          </div>
          <div class="cat-card-meta">
            <span class="cat-card-title">{{ product.title }}</span>
            <span class="cat-card-price">{{ product.price | money }}</span>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <nav class="catalog-pager">{{ paginate | default_pagination }}</nav>
    {% endif %}
  {% else %}
    <p class="catalog-empty">No products in here yet. Add products in Shopify and they show up automatically.</p>
  {% endif %}
</section>
{% endpaginate %}

{% schema %}
{ "name": "MV Catalog", "settings": [], "blocks": [] }
{% endschema %}
