<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0d0d0b">
  <title>{{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Fira+Sans+Condensed:wght@400;500;700;900&display=swap" rel="stylesheet">
  {{ 'mv-styles.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="mv-locked">
  <main>{{ content_for_layout }}</main>
</body>
</html>
