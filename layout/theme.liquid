<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0d0d0b">
  <link rel="canonical" href="{{ canonical_url }}">
  <title>{% if page_title %}{{ page_title }}{% else %}{{ shop.name }}{% endif %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Fira+Sans+Condensed:wght@400;500;700;900&display=swap" rel="stylesheet">
  {{ 'mv-styles.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}

  <style>
  /* Cart upsells */
  #cartUpsells{ padding:0 16px; display:flex; flex-direction:column; gap:8px; }
  .cu-upsell{ display:flex; align-items:center; gap:12px; padding:12px; background:#111110; border:1px solid rgba(236,233,226,.1); border-radius:6px; }
  .cu-img{ width:48px; height:60px; background:#1c1c19; border-radius:4px; overflow:hidden; flex:none; }
  .cu-img img{ width:100%; height:100%; object-fit:cover; }
  .cu-img-empty{ width:100%; height:100%; }
  .cu-info{ flex:1; min-width:0; }
  .cu-label{ font-family:'Fira Sans Condensed',sans-serif; font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:#ffb800; margin:0 0 2px; }
  .cu-name{ font-family:'Fira Sans Condensed',sans-serif; font-size:13px; color:#ECE9E2; margin:0 0 2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .cu-price{ font-family:'Fira Sans Condensed',sans-serif; font-size:12px; color:#9b988f; margin:0; }
  .cu-btn{ flex:none; background:#ECE9E2; color:#0d0d0b; border:none; border-radius:6px; padding:8px 14px; font-family:'Fira Sans Condensed',sans-serif; font-weight:700; font-size:11px; letter-spacing:.08em; text-transform:uppercase; cursor:pointer; white-space:nowrap; }
  .cu-btn:hover{ background:#fff; }
  .cu-btn:disabled{ opacity:.5; cursor:not-allowed; }
  .cu-protection{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 12px; background:rgba(111,191,142,.06); border:1px solid rgba(111,191,142,.18); border-radius:6px; }
  .cu-pp-left{ display:flex; align-items:center; gap:8px; }
  .cu-pp-icon{ width:22px; height:22px; color:#8fd3a8; flex:none; }
  .cu-pp-icon svg{ width:100%; height:100%; }
  .cu-pp-name{ font-family:'Fira Sans Condensed',sans-serif; font-size:12px; color:#ECE9E2; margin:0 0 1px; }
  .cu-pp-price{ font-family:'Fira Sans Condensed',sans-serif; font-size:11px; color:#9b988f; margin:0; }
  .cu-pp-btn{ flex:none; background:transparent; color:#8fd3a8; border:1px solid rgba(143,211,168,.3); border-radius:6px; padding:6px 12px; font-family:'Fira Sans Condensed',sans-serif; font-weight:700; font-size:11px; letter-spacing:.06em; text-transform:uppercase; cursor:pointer; white-space:nowrap; }
  .cu-pp-btn:hover{ background:rgba(143,211,168,.1); }
  .cu-pp-btn:disabled{ opacity:.5; cursor:not-allowed; }
  /* Payment icons */
  .cart-payments{ display:flex; flex-wrap:wrap; justify-content:center; gap:5px; margin-top:10px; }
  .cart-payment-icon{ height:22px; width:auto; border-radius:3px; opacity:.65; }
  </style>
</head>
<body>
  {% comment %}— Redirect handlers: account register → my-account, affiliate flows → portal —{% endcomment %}
  {% if customer %}
  <script>
    (function(){
      if(sessionStorage.getItem('mv_acct_redirect')){
        sessionStorage.removeItem('mv_acct_redirect');
        if(window.location.pathname !== '/pages/my-account'){
          window.location.replace('/pages/my-account');
        }
      } else if(sessionStorage.getItem('mv_aff_new_reg')){
        sessionStorage.removeItem('mv_aff_new_reg');
        window.location.replace('https://Mountveritas.bixgrow.com/register');
      } else if(sessionStorage.getItem('mv_aff_redirect')){
        sessionStorage.removeItem('mv_aff_redirect');
        if(window.location.pathname !== '/pages/affiliate-dashboard'){
          window.location.replace('/pages/affiliate-dashboard');
        }
      }
    })();
  </script>
  {% endif %}

  <div class="pattern-wall" id="patternWall" aria-hidden="true"></div>

  <nav class="nav" aria-label="Main">
  <a class="wordmark" href="{{ routes.root_url }}" aria-label="Mount Veritas — home"><img src="{{ 'mv-wordmark.png' | asset_url }}" alt="Mount Veritas — See it. Believe it. Obtain it."></a>
  <span class="nav-icons">
    <a href="{{ routes.account_url }}" aria-label="Account">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="8" r="3.6"/><path d="M4.5 20c1.4-3.6 4.2-5.2 7.5-5.2s6.1 1.6 7.5 5.2"/></svg>
    </a>
    <button class="nav-search" id="searchToggle" type="button" aria-label="Search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="11" cy="11" r="6.5"/><path d="M16 16l4.5 4.5"/></svg>
    </button>
    <button class="cart-toggle" id="cartToggle" type="button" aria-label="Cart">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M5.5 8h13l-1.1 12h-10.8z"/><path d="M9 8V6.8a3 3 0 0 1 6 0V8"/></svg>
      <span class="cart-count" id="cartCount"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
    </button>
  </span>
</nav>

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  <footer>
    <div class="join">
      <h3 class="join-title">Join the Climb</h3>
      {% form 'customer' %}
        {% if form.posted_successfully? %}
          <p class="join-done">You're in. Welcome to the climb.</p>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="join-row">
            <input type="email" name="contact[email]" placeholder="email address" aria-label="Email address" required>
            <button type="submit" class="join-arrow" aria-label="Join the climb">&rarr;</button>
          </div>
          {% if form.errors %}<p class="join-err">That didn't go through &mdash; check the email and try again.</p>{% endif %}
        {% endif %}
      {% endform %}
      <p class="join-brand"><span class="fm">Mount Veritas &middot; MMXXVI</span></p>
    </div>
    <div class="foot-bottom">
      <span class="foot-tag">See it &middot; Believe it &middot; Obtain it</span>
      <nav class="foot-links" aria-label="Footer">
        <a href="{{ settings.footer_contact_url | default: '/pages/contact-us' }}">Contact us</a>
        <a href="{{ settings.footer_client_url | default: '/pages/client-services' }}">Client services</a>
        <a href="{{ settings.footer_legal_url | default: '/pages/legal-notices' }}">Legal notices</a>
        <a href="{{ settings.footer_affiliate_url | default: '/pages/affiliate' }}">Affiliate program</a>
        <a href="{{ settings.social_url | default: '#' }}"{% if settings.social_url != blank %} target="_blank" rel="noopener"{% endif %}>Social</a>
      </nav>
    </div>
  </footer>

  <div class="cart-overlay" id="cartOverlay" aria-hidden="true"></div>
  <aside class="cart-drawer" id="cartDrawer" aria-label="Cart" aria-hidden="true">
    <div class="cart-head">
      <span class="cart-title">Your Cart</span>
      <button class="cart-close" id="cartClose" type="button" aria-label="Close cart">&times;</button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div id="cartUpsells"></div>
    <div class="cart-foot">
      <div class="cart-subtotal-row"><span>Subtotal</span><span id="cartSubtotal">$0.00</span></div>
      <a class="cart-checkout" href="/checkout">Checkout</a>
      <div class="cart-payments">
        {%- assign payment_types = "shopify_pay,visa,master,american_express,diners_club,discover,apple_pay,google_pay" | split: "," -%}
        {%- for type in payment_types -%}
          <img class="cart-payment-icon" src="{{ type | payment_type_img_url: 'small' }}" alt="{{ type | replace: '_', ' ' }}" width="38" height="24" loading="lazy">
        {%- endfor -%}
      </div>
    </div>
  </aside>

  <script>
  window.MV_CART = {
    ea: {
      variantId: {{ settings.cart_ea_product.variants.first.id | default: 0 }},
      productId: {{ settings.cart_ea_product.id | default: 0 }},
      title: {{ settings.cart_ea_product.title | default: "" | json }},
      price: {{ settings.cart_ea_product.price | default: 0 }},
      image: {{ settings.cart_ea_product.featured_image | image_url: width: 120 | default: "" | json }},
      label: {{ settings.cart_ea_label | default: "Exclusive add-on" | json }}
    },
    pp: {
      variantId: {{ settings.cart_pp_product.variants.first.id | default: 0 }},
      productId: {{ settings.cart_pp_product.id | default: 0 }},
      title: {{ settings.cart_pp_product.title | default: "" | json }},
      price: {{ settings.cart_pp_product.price | default: 0 }}
    }
  };
  </script>

  <div class="search-overlay" id="searchOverlay" aria-hidden="true">
    <button class="search-close" id="searchClose" type="button" aria-label="Close search">&times;</button>
    <div class="search-box">
      <div class="search-field">
        <svg class="search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="11" cy="11" r="6.5"/><path d="M16 16l4.5 4.5"/></svg>
        <input type="search" id="searchInput" placeholder="Search products" aria-label="Search products" autocomplete="off">
      </div>
      <div class="search-results" id="searchResults" aria-live="polite"></div>
    </div>
  </div>

  {{ 'mv-script.js' | asset_url | script_tag }}
</body>
</html>


